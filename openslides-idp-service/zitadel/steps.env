# By using the FirstInstance section, you can overwrite the DefaultInstance
# configuration for the first instance created by zitadel setup.
# See https://github.com/zitadel/zitadel/blob/v4.15.3/cmd/setup/steps.yaml
# for more details and additional settings.
ZITADEL_FIRSTINSTANCE_PATPATH=/zitadel/bootstrap/admin.pat
ZITADEL_FIRSTINSTANCE_LOGINCLIENTPATPATH=/zitadel/bootstrap/login-client.pat
ZITADEL_FIRSTINSTANCE_INSTANCENAME=OpenSlides
ZITADEL_FIRSTINSTANCE_DEFAULTLANGUAGE=de
ZITADEL_FIRSTINSTANCE_ORG_NAME=OpenSlides
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=openslides-admin
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_FIRSTNAME=OpenSlides
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_LASTNAME=Admin
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=Password1!
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=false
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME=OpenSlides-Service
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME=OpenSlides Service Account
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_EXPIRATIONDATE=2099-01-01T00:00:00Z
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_USERNAME=OpenSlides-Login
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_NAME=OpenSlides Login Account
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_PAT_EXPIRATIONDATE=2099-01-01T00:00:00Z
