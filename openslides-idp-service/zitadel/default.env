# See https://github.com/zitadel/zitadel/blob/v4.15.3/cmd/defaults.yaml
# for more details and additional settings
#
# Zitadel connection settings
ZITADEL_PORT=8080
ZITADEL_EXTERNALPORT=8000
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNAL_SECURE=true
ZITADEL_TLS_MODE=external
ZITADEL_TLS_ENABLED=false

# Database settings
ZITADEL_DATABASE_POSTGRES_HOST=postgres
ZITADEL_DATABASE_POSTGRES_PORT=5432
ZITADEL_DATABASE_POSTGRES_DATABASE=zitadel
ZITADEL_DATABASE_POSTGRES_USER_USERNAME=zitadel
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=zitadel
ZITADEL_DATABASE_POSTGRES_USER_SSL_MODE=disable
ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME=openslides
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=openslides
ZITADEL_DATABASE_POSTGRES_ADMIN_SSL_MODE=disable

# Identification of the machine
ZITADEL_MACHINE_IDENTIFICATION_PRIVATEIP_ENABLED=true
ZITADEL_MACHINE_IDENTIFICATION_HOSTNAME_ENABLED=false
ZITADEL_MACHINE_IDENTIFICATION_WEBHOOK_ENABLED=false

# Login
ZITADEL_OIDC_DEFAULTLOGINURLV2=https://localhost:8000/ui/v2/login/login?authRequest=
ZITADEL_OIDC_DEFAULTLOGOUTURLV2=https://localhost:8000/ui/v2/login/logout?post_logout_redirect=

# Zitadel Instance
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_DEFAULTINSTANCE_INSTANCENAME=OpenSlides
ZITADEL_DEFAULTINSTANCE_DEFAULTLANGUAGE=de
ZITADEL_DEFAULTINSTANCE_ORG_NAME=OpenSlides
ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_USERNAME=openslides-admin
ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_FIRSTNAME=OpenSlides
ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_LASTNAME=Admin
ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_EMAIL_VERIFIED=true
ZITADEL_DEFAULTINSTANCE_ORG_HUMAN_PASSWORD=Password1!
# TOSLink: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_TOSLINK
# PrivacyLink: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_PRIVACYLINK
# HelpLink: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_HELPLINK
# SupportEmail: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_SUPPORTEMAIL
# DocsLink: https://zitadel.com/docs # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_DOCSLINK
# CustomLink: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_CUSTOMLINK
# CustomLinkText: "" # ZITADEL_DEFAULTINSTANCE_PRIVACYPOLICY_CUSTOMLINKTEXT
 
# Email settings
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_HOST=mailhog:1025
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_USER=openslides
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_SMTP_PASSWORD=changethis
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_FROM=noreply@openslides.com 
ZITADEL_DEFAULTINSTANCE_SMTPCONFIGURATION_FROMNAME=OpenSlides

# LogLevel
ZITADEL_INSTRUMENTATION_LOG_LEVEL=INFO
